generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Ads_Leads {
  id           Int       @id @default(autoincrement())
  fullName     String
  email        String
  phone        String
  utm_source   String?
  utm_medium   String?
  utm_campaign String?
  utm_term     String?
  utm_content  String?
  landing_page String?
  gclid        String?
  status       String?   @default("active")
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
}

model Batches {
  id             Int       @id @default(autoincrement())
  courseName     String    @db.VarChar(150)
  batchId        String    @unique @db.VarChar(50)
  startDate      DateTime  @db.Date
  endDate        DateTime  @db.Date
  completionDate DateTime? @db.Date
  weekType       String?   @db.VarChar(30)
  timings        String?   @db.VarChar(50)
  noOfStudents   Int?      @default(0)
  status         String?   @default("Active") @db.VarChar(20)
}

model DaWebinars {
  webinarId   Int       @id(map: "dawebinars_pkey") @default(autoincrement())
  title       String    @db.VarChar(255)
  dateTime    DateTime  @db.Timestamp(6)
  description String?
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
  status      String?   @default("Running") @db.VarChar(50)
}

model DefaultSyllabus {
  id        Int      @id @default(1)
  fileName  String
  updatedAt DateTime
  fileUrl   String?
  mimeType  String?
  fileSize  Int?
}

model Employees {
  empid         Int       @id(map: "employees_pkey") @default(autoincrement())
  fullname      String    @db.VarChar(100)
  email         String    @unique(map: "employees_email_key") @db.VarChar(120)
  phone         String?   @db.VarChar(20)
  designation   String?   @db.VarChar(100)
  dateofjoining DateTime? @db.Date
  dateofexit    DateTime? @db.Date
  status        String?   @default("working") @db.VarChar(20)
  isactive      Boolean?  @default(true)
  createdat     DateTime? @default(now()) @db.Timestamp(6)
  updatedat     DateTime? @default(now()) @db.Timestamp(6)
}

model EnrollmentsByAdSource {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(150)
  count Int?   @default(0)
}

model EnrollmentsByCourse {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(150)
  count Int?   @default(0)
}

model EnrollmentsByOwner {
  id    Int    @id(map: "enrollmentbyowner_pkey") @default(autoincrement())
  name  String @db.VarChar(150)
  count Int?   @default(0)
}

model EnrollmentsBySource {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(150)
  count Int?   @default(0)
}

model FeeInstallments {
  id                Int                @id(map: "feeinstallments_pkey") @default(autoincrement())
  installmentNo     Int
  amount            Decimal            @db.Decimal(12, 2)
  dueDate           DateTime           @db.Timestamp(6)
  status            String             @default("Due")
  enrollmentNumber  String?            @db.VarChar(50)
  courseId          Int?
  daStudents_Course daStudents_Course? @relation(fields: [courseId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model FeePayments {
  id                Int                @id(map: "feepayments_pkey") @default(autoincrement())
  installmentNo     Int
  amountPaid        Decimal            @db.Decimal(12, 2)
  paidDate          DateTime?          @default(now()) @db.Timestamp(6)
  paymentMode       String
  enrollmentNumber  String?            @db.VarChar(50)
  courseId          Int?
  daStudents_Course daStudents_Course? @relation(fields: [courseId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model LeadActivity {
  id             Int        @id @default(autoincrement())
  leadId         Int
  activityType   String
  title          String
  description    String?
  meta           Json?
  leadOwner      String?    @db.VarChar(255)
  createdAt      DateTime   @default(now())
  nextFollowupAt DateTime?  @db.Timestamp(6)
  daleads        daleads    @relation(fields: [leadId], references: [leadId])
  LeadEmail      LeadEmail?
}

model LeadEmail {
  id           Int           @id @default(autoincrement())
  leadId       Int
  activityId   Int?          @unique
  toEmail      String
  fromEmail    String
  subject      String
  bodyHtml     String
  status       String        @default("sent")
  errorMessage String?
  sentAt       DateTime      @default(now())
  fileName     String?
  fileUrl      String?
  LeadActivity LeadActivity? @relation(fields: [activityId], references: [id])
  daleads      daleads       @relation(fields: [leadId], references: [leadId])
}

model LeadTag {
  id          Int      @id @default(autoincrement())
  tag         String
  leadId      Int
  createdById Int?
  createdAt   DateTime @default(now())
  daleads     daleads  @relation(fields: [leadId], references: [leadId])
}

model LeadsByAdSource {
  id    Int    @id(map: "leadbyadsource_pkey") @default(autoincrement())
  name  String @db.VarChar(255)
  count Int?   @default(0)
}

model LeadsByCourse {
  id    Int    @id @default(autoincrement())
  name  String @db.VarChar(150)
  count Int?   @default(0)
}

model LeadsByOwner {
  id    Int    @id(map: "leadbyowner_pkey") @default(autoincrement())
  name  String @db.VarChar(150)
  count Int?   @default(0)
}

model LeadsBySource {
  id    Int    @id @default(autoincrement())
  name  String @db.VarChar(150)
  count Int?   @default(0)
}

model RoundRobinCounter {
  id        Int      @id(map: "roundRobinCounter_pkey")
  index     Int      @default(0)
  updatedAt DateTime @default(now()) @db.Timestamp(6)
}

model UserLoginDetails {
  username   String    @id(map: "userlogindetails_pkey") @db.VarChar(120)
  password   String    @db.VarChar(255)
  role       String    @db.VarChar(20)
  lastlogin  DateTime? @db.Timestamp(6)
  logincount Int?      @default(0)
  status     String?   @default("active") @db.VarChar(20)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Webinar_Feedback {
  id                BigInt    @id @default(autoincrement())
  fullName          String    @db.VarChar(100)
  email             String    @db.VarChar(150)
  whatsappNumber    String    @db.VarChar(20)
  webinarRating     Int
  clarityLevel      String    @db.VarChar(30)
  helpfulParts      String[]
  targetRoles       String[]
  biggestChallenges String[]
  programInterest   String    @db.VarChar(50)
  sessionFeedback   String?
  createdAt         DateTime? @default(now()) @db.Timestamp(6)
  status            String?   @default("ACTIVE") @db.VarChar(20)
}

model Webinar_Registrations {
  sno         Int      @id @default(autoincrement())
  webinarId   String   @db.VarChar(100)
  fullName    String   @db.VarChar(150)
  email       String   @db.VarChar(150)
  phone       String   @db.VarChar(20)
  status      String?  @default("registered") @db.VarChar(50)
  createdDate DateTime @default(now()) @db.Timestamp(6)
}

model daStudents_Course {
  id               Int               @id @default(autoincrement())
  enrollmentNumber String            @db.VarChar(255)
  courseJoined     String?
  totalFee         Decimal?          @db.Decimal(12, 2)
  feePaid          Decimal?          @default(0) @db.Decimal(12, 2)
  feeBalance       Decimal?          @db.Decimal(12, 2)
  installments     Int?
  studentId        String?           @unique(map: "dastudents_course_studentid_unique") @db.VarChar(50)
  FeeInstallments  FeeInstallments[]
  FeePayments      FeePayments[]
  dastudents       dastudents        @relation(fields: [enrollmentNumber], references: [enrollmentNumber], onDelete: Cascade, onUpdate: NoAction)
}

model daleads {
  leadId         Int              @id @default(autoincrement())
  fullName       String
  email          String           @unique(map: "daleads_email_unique")
  phone          String?          @unique(map: "daleads_phone_unique")
  leadSource     String?          @default("web_site")
  adSource       String?
  createdAt      DateTime?        @default(now())
  leadStatus     String?          @default("New")
  leadOwner      String?          @db.VarChar(255)
  LeadActivity   LeadActivity[]
  LeadEmail      LeadEmail[]
  LeadTag        LeadTag[]
  daleads_Course daleads_Course[]
  dastudents     dastudents[]
}

model daleads_Course {
  id               Int      @id @default(autoincrement())
  leadId           Int
  courseInterested String?  @db.VarChar(255)
  enrollmentStatus String?  @default("Not Enrolled") @db.VarChar(100)
  Remarks          String?  @db.VarChar(255)
  updatedAt        DateTime @default(now()) @db.Timestamp(6)
  daleads          daleads  @relation(fields: [leadId], references: [leadId], onDelete: Cascade, onUpdate: NoAction, map: "fk_daleads_course")
}

model dastudents {
  leadId            Int?
  fullName          String
  email             String?
  phone             String?
  status            String              @default("active")
  createdAt         DateTime?           @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?           @default(now()) @db.Timestamp(6)
  leadowner         String?             @db.VarChar(255)
  enrollmentNumber  String              @id @db.VarChar(50)
  daStudents_Course daStudents_Course[]
  daleads           daleads?            @relation(fields: [leadId], references: [leadId])
}

model webinars {
  webinarId            String   @id @db.VarChar(100)
  web_Date             DateTime @db.Timestamp(6)
  no_of_Registractions Int      @default(0)
  status               String   @default("active") @db.VarChar(50)
}

model WebsiteLead {
  leadId         Int      @id @default(autoincrement())

  fullName       String?
  email          String?
  phone          String?

  profileType    String?
  currentJobRole String?
  experience     String?

  goal           String?
  preferredBatch String?
  city           String?

  leadSource     String?
  leadStatus     String   @default("new")

  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmTerm        String?
  utmContent     String?
  gclid          String?

  sourcePage     String?
  leadType       String?

  createdAt      DateTime @default(now())

  @@map("website_leads")
}